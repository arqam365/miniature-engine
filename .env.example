# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database (NeonDB — get both URLs from neon.tech dashboard)
DATABASE_URL="postgresql://user:password@ep-xxx.pooler.neon.tech/cognivia_erp?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/cognivia_erp?sslmode=require"

# Redis (Upstash — get from upstash.com dashboard)
REDIS_URL="rediss://default:password@xxx.upstash.io:6379"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRY=30d

# File Storage (Cloudflare R2 — S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cognivia-files
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Email (Resend — get from resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
SMTP_FROM=noreply@cognivia.com

# SMS Gateway (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Platform
PLATFORM_OWNER_EMAIL=admin@revzion.com
PLATFORM_OWNER_PASSWORD=changeme123
WS_PORT=4001
